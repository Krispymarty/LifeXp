PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/life-xp

# Alternative: paste your MongoDB Atlas connection string here.
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Set to true if you want the API to run with sample in-memory data when MongoDB is unavailable.
LIFE_XP_DEMO=false

# Set to true if the server should exit instead of falling back to demo mode when MongoDB is unavailable.
REQUIRE_MONGO=false
